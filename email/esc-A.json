"<!DOCTYPE html>\n<html lang=\"sk\" xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:o=\"urn:schemas-microsoft-com:office:office\">\n<head>\n  <title>Dopyt prijatý — Orostone</title>\n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"color-scheme\" content=\"dark light\">\n  <meta name=\"supported-color-schemes\" content=\"dark light\">\n  <style>\n    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap');\n    body { margin:0; padding:0; font-family:'Montserrat',Arial,sans-serif; -webkit-font-smoothing:antialiased; -ms-text-size-adjust:100%; -webkit-text-size-adjust:100%; }\n    table { border-spacing:0; border-collapse:collapse; }\n    img { border:0; outline:none; text-decoration:none; -ms-interpolation-mode:bicubic; }\n    a { text-decoration:none; }\n    @media screen and (max-width:620px) {\n      .oro-pad { padding-left:24px !important; padding-right:24px !important; }\n      .oro-pad-img { padding-left:16px !important; padding-right:16px !important; }\n      .oro-gcell { display:block !important; width:100% !important; max-width:100% !important; padding:0 0 12px 0 !important; }\n    }\n  </style>\n</head>\n<body style=\"margin:0; padding:0; background-color:#131312;\">\n\n  <!-- preheader -->\n  <div style=\"display:none; max-height:0; overflow:hidden; opacity:0; color:#131312; font-size:1px; line-height:1px;\">\n    Ozveme sa vám spravidla do 24 hodín — doladíme detaily a pripravíme orientačnú cenu na mieru.&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;\n  </div>\n\n  <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background-color:#131312;\">\n    <tr>\n      <td align=\"center\" style=\"padding:34px 16px 44px 16px;\">\n\n        <!-- logo -->\n        <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width:600px; margin:0 auto;\">\n          <tr><td align=\"center\" style=\"padding-bottom:22px;\">\n            <a href=\"https://orostone.sk\" target=\"_blank\"><img src=\"https://orostone.sk/images/orostone-logo-hd.png\" alt=\"Orostone\" height=\"38\" style=\"height:38px; display:inline-block;\"></a>\n          </td></tr>\n        </table>\n\n        <!-- card -->\n        <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width:600px; margin:0 auto; background-color:#1A1A1A; border-radius:16px; overflow:hidden; border:1px solid rgba(236,212,136,.16);\">\n\n          <!-- eyebrow + heading -->\n          <tr><td class=\"oro-pad\" style=\"padding:42px 44px 0 44px;\" align=\"center\">\n            <span style=\"font-size:11px; font-weight:700; letter-spacing:.26em; text-transform:uppercase; color:#ECD488;\">Dopyt prijatý</span>\n          </td></tr>\n          <tr><td class=\"oro-pad\" style=\"padding:16px 44px 0 44px;\" align=\"center\">\n            <h1 style=\"margin:0; font-family:'Montserrat',Arial,sans-serif; font-size:27px; font-weight:700; color:#F9F9F7; letter-spacing:-.02em; line-height:1.25;\">Ďakujeme, {{first(split(1.name; \" \"))}}.</h1>\n          </td></tr>\n\n          <!-- body -->\n          <tr><td class=\"oro-pad\" style=\"padding:18px 44px 0 44px;\">\n            <p style=\"margin:0 0 14px 0; font-size:15px; font-weight:300; color:rgba(249,249,247,.72); line-height:1.7;\">\n              Ozveme sa vám spravidla do 24 hodín — spolu doladíme detaily a pripravíme <strong style=\"font-weight:600; color:#F9F9F7;\">orientačnú cenu na mieru</strong>.\n            </p>\n            <p style=\"margin:0; font-size:15px; font-weight:300; color:rgba(249,249,247,.72); line-height:1.7;\">\n              Kým čakáte, pozrite si kuchyne, ktoré sme už dodali — <strong style=\"font-weight:600; color:#F9F9F7;\">skutočný sinterovaný kameň vo veľkej ploche</strong>, nie vizualizácie.\n            </p>\n          </td></tr>\n\n          <!-- hero photo -->\n          <tr><td class=\"oro-pad-img\" style=\"padding:26px 36px 0 36px;\">\n            <img src=\"https://pracovnadoska.orostone.sk/img/real-gold.webp\" alt=\"Kuchynský ostrov s waterfall hranou — dekor Arden Gold\" width=\"528\" style=\"display:block; width:100%; max-width:528px; height:auto; border-radius:12px;\">\n          </td></tr>\n\n          <!-- next steps -->\n          <tr><td class=\"oro-pad\" style=\"padding:30px 44px 0 44px;\" align=\"center\">\n            <span style=\"font-size:11px; font-weight:700; letter-spacing:.22em; text-transform:uppercase; color:#ECD488;\">Čo bude nasledovať</span>\n          </td></tr>\n          <tr><td class=\"oro-pad\" style=\"padding:18px 44px 0 44px;\">\n            <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n              <tr>\n                <td width=\"34\" valign=\"top\" style=\"padding-bottom:14px;\"><div style=\"width:26px; height:26px; border-radius:50%; border:1px solid rgba(236,212,136,.55); color:#ECD488; font-size:12px; font-weight:600; text-align:center; line-height:25px;\">1</div></td>\n                <td valign=\"top\" style=\"padding:2px 0 14px 4px; font-size:14.5px; font-weight:300; color:rgba(249,249,247,.85); line-height:1.55;\">Ozveme sa vám a doladíme rozmery, dekor a hrúbku.</td>\n              </tr>\n              <tr>\n                <td width=\"34\" valign=\"top\" style=\"padding-bottom:14px;\"><div style=\"width:26px; height:26px; border-radius:50%; border:1px solid rgba(236,212,136,.55); color:#ECD488; font-size:12px; font-weight:600; text-align:center; line-height:25px;\">2</div></td>\n                <td valign=\"top\" style=\"padding:2px 0 14px 4px; font-size:14.5px; font-weight:300; color:rgba(249,249,247,.85); line-height:1.55;\">Pripravíme <strong style=\"font-weight:600; color:#fff;\">orientačnú cenu</strong> a dohodneme <strong style=\"font-weight:600; color:#fff;\">bezplatné zameranie</strong>.</td>\n              </tr>\n              <tr>\n                <td width=\"34\" valign=\"top\"><div style=\"width:26px; height:26px; border-radius:50%; border:1px solid rgba(236,212,136,.55); color:#ECD488; font-size:12px; font-weight:600; text-align:center; line-height:25px;\">3</div></td>\n                <td valign=\"top\" style=\"padding:2px 0 0 4px; font-size:14.5px; font-weight:300; color:rgba(249,249,247,.85); line-height:1.55;\">Platne si môžete pozrieť aj naživo v showroome v Bošanoch.</td>\n              </tr>\n            </table>\n          </td></tr>\n\n          <!-- divider -->\n          <tr><td class=\"oro-pad\" style=\"padding:30px 44px 22px 44px;\"><div style=\"height:1px; background-color:rgba(236,212,136,.20);\"></div></td></tr>\n\n          <!-- gallery label -->\n          <tr><td class=\"oro-pad\" style=\"padding:0 44px 4px 44px;\" align=\"center\">\n            <span style=\"font-size:11px; font-weight:700; letter-spacing:.22em; text-transform:uppercase; color:#ECD488;\">Skutočné kuchyne, ktoré sme dodali</span>\n          </td></tr>\n          <tr><td class=\"oro-pad\" style=\"padding:6px 44px 20px 44px;\" align=\"center\">\n            <p style=\"margin:0; font-size:13.5px; font-weight:300; color:rgba(249,249,247,.60); line-height:1.6;\">Od svetlého mramoru po výrazné dekory.</p>\n          </td></tr>\n\n          <!-- gallery 2x2 -->\n          <tr><td class=\"oro-pad-img\" style=\"padding:0 36px 0 36px;\">\n            <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n              <tr>\n                <td class=\"oro-gcell\" width=\"50%\" valign=\"top\" style=\"padding:0 6px 12px 0;\">\n                  <img src=\"https://pracovnadoska.orostone.sk/img/real-travertine.webp\" alt=\"Kuchyňa v orechu s ostrovom — dekor Roman Travertine\" width=\"252\" style=\"display:block; width:100%; height:auto; border-radius:10px;\">\n                  <div style=\"padding:8px 2px 0 2px; font-size:12.5px; color:#F9F9F7; font-weight:600;\">Roman Travertine</div>\n                  <div style=\"padding:1px 2px 0 2px; font-size:11.5px; color:rgba(249,249,247,.55); font-weight:300;\">Kuchyňa v orechu + ostrov</div>\n                </td>\n                <td class=\"oro-gcell\" width=\"50%\" valign=\"top\" style=\"padding:0 0 12px 6px;\">\n                  <img src=\"https://pracovnadoska.orostone.sk/img/real-walnut.webp\" alt=\"Zástena a pracovná doska — dekor Statuario Diamante\" width=\"252\" style=\"display:block; width:100%; height:auto; border-radius:10px;\">\n                  <div style=\"padding:8px 2px 0 2px; font-size:12.5px; color:#F9F9F7; font-weight:600;\">Statuario Diamante</div>\n                  <div style=\"padding:1px 2px 0 2px; font-size:11.5px; color:rgba(249,249,247,.55); font-weight:300;\">Zástena a pracovná doska</div>\n                </td>\n              </tr>\n              <tr>\n                <td class=\"oro-gcell\" width=\"50%\" valign=\"top\" style=\"padding:0 6px 0 0;\">\n                  <img src=\"https://pracovnadoska.orostone.sk/img/real-navy.webp\" alt=\"Pracovná doska a zástena s modrými skrinkami — dekor Yabo White\" width=\"252\" style=\"display:block; width:100%; height:auto; border-radius:10px;\">\n                  <div style=\"padding:8px 2px 0 2px; font-size:12.5px; color:#F9F9F7; font-weight:600;\">Yabo White</div>\n                  <div style=\"padding:1px 2px 0 2px; font-size:11.5px; color:rgba(249,249,247,.55); font-weight:300;\">Doska a zástena</div>\n                </td>\n                <td class=\"oro-gcell\" width=\"50%\" valign=\"top\" style=\"padding:0 0 0 6px;\">\n                  <img src=\"https://pracovnadoska.orostone.sk/img/real-brick.webp\" alt=\"Kuchynský ostrov s tmavým rámom — dekor Super White Extra\" width=\"252\" style=\"display:block; width:100%; height:auto; border-radius:10px;\">\n                  <div style=\"padding:8px 2px 0 2px; font-size:12.5px; color:#F9F9F7; font-weight:600;\">Super White Extra</div>\n                  <div style=\"padding:1px 2px 0 2px; font-size:11.5px; color:rgba(249,249,247,.55); font-weight:300;\">Ostrov s tmavým rámom</div>\n                </td>\n              </tr>\n            </table>\n          </td></tr>\n\n          <!-- rating -->\n          <tr><td class=\"oro-pad\" style=\"padding:22px 44px 0 44px;\" align=\"center\">\n            <span style=\"font-size:13px; font-weight:400; color:rgba(249,249,247,.75);\">\n              <span style=\"color:#ECD488; letter-spacing:1px;\">★★★★★</span>&nbsp;&nbsp;Hodnotenie <strong style=\"color:#F9F9F7; font-weight:600;\">5,0</strong> na Google\n            </span>\n          </td></tr>\n\n          <!-- CTA -->\n          <tr><td class=\"oro-pad\" style=\"padding:24px 44px 0 44px;\" align=\"center\">\n            <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr>\n              <td style=\"background-color:#ECD488; border-radius:12px;\">\n                <a href=\"https://orostone.sk/realizacie\" target=\"_blank\" style=\"display:inline-block; font-family:'Montserrat',Arial,sans-serif; font-size:11px; font-weight:700; color:#1A1A1A; letter-spacing:.14em; text-transform:uppercase; padding:15px 30px;\">Pozrieť viac realizácií &#8594;</a>\n              </td>\n            </tr></table>\n          </td></tr>\n\n          <!-- showroom + phone -->\n          <tr><td class=\"oro-pad\" style=\"padding:22px 44px 0 44px;\" align=\"center\">\n            <p style=\"margin:0 0 6px 0; font-size:13px; font-weight:300; color:rgba(249,249,247,.62); line-height:1.6;\">\n              <span style=\"color:#ECD488;\">&#9679;</span>&nbsp; Showroom · renesančný kaštieľ, Bošany\n            </p>\n            <p style=\"margin:0; font-size:13px; font-weight:300; color:rgba(249,249,247,.62); line-height:1.6;\">\n              Ponáhľate sa? Volajte <a href=\"tel:+421917588738\" style=\"color:#ECD488; font-weight:600;\">0917 588 738</a>\n            </p>\n          </td></tr>\n\n          <!-- divider -->\n          <tr><td class=\"oro-pad\" style=\"padding:30px 44px 0 44px;\"><div style=\"height:1px; background-color:rgba(236,212,136,.20);\"></div></td></tr>\n\n          <!-- footer -->\n          <tr><td class=\"oro-pad\" style=\"padding:26px 44px 38px 44px;\">\n            <p style=\"margin:0 0 2px 0; font-size:14.5px; font-weight:300; color:rgba(249,249,247,.72);\">S pozdravom,</p>\n            <p style=\"margin:0 0 18px 0; font-size:14.5px; font-weight:700; color:#F9F9F7;\">Team Orostone</p>\n            <p style=\"margin:0 0 2px 0; font-size:12px; font-weight:600; color:rgba(249,249,247,.6);\">Orostone s.r.o.</p>\n            <p style=\"margin:0 0 1px 0; font-size:12px; font-weight:300; color:rgba(249,249,247,.5);\">Landererova 8, 811 09 Bratislava — Staré Mesto</p>\n            <p style=\"margin:6px 0 0 0; font-size:12px;\"><a href=\"https://orostone.sk\" target=\"_blank\" style=\"color:rgba(249,249,247,.62);\">orostone.sk</a> &nbsp;·&nbsp; <a href=\"mailto:info@orostone.sk\" style=\"color:#ECD488;\">info@orostone.sk</a></p>\n          </td></tr>\n\n        </table>\n        <!-- /card -->\n\n        <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width:600px; margin:0 auto;\">\n          <tr><td align=\"center\" style=\"padding-top:22px;\">\n            <span style=\"font-size:11px; font-weight:300; color:rgba(249,249,247,.35);\">© 2026 Orostone s.r.o. · sinterovaný kameň pre kuchyne a interiéry</span>\n          </td></tr>\n        </table>\n\n      </td>\n    </tr>\n  </table>\n\n</body>\n</html>\n"